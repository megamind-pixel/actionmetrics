// Prisma Schema — ActionMetrics Kenya
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER
  ADMIN
  VIEWER
}

enum InstitutionType {
  Primary
  Secondary
  University
}

enum Level {
  Primary
  Secondary
  University
}

enum ScoreType {
  percent
  gpa
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(VIEWER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}

model Institution {
  id        String          @id @default(cuid())
  instId    String          @unique // e.g. INST-0001
  name      String
  type      InstitutionType
  county    String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  students  Student[]

  @@map("institutions")
}

model Student {
  id          String      @id @default(cuid())
  stuId       String      @unique // e.g. STU-00001
  name        String
  instId      String
  level       Level
  class       String
  programme   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  institution Institution @relation(fields: [instId], references: [instId], onDelete: Cascade)
  results     Result[]

  @@map("students")
}

model Result {
  id         String    @id @default(cuid())
  stuId      String
  subject    String
  score      Float
  scoreType  ScoreType @default(percent)
  normalised Float
  term       String
  year       String
  createdAt  DateTime  @default(now())

  student    Student   @relation(fields: [stuId], references: [stuId], onDelete: Cascade)

  @@map("results")
}

model ActivityLog {
  id        String   @id @default(cuid())
  message   String
  createdAt DateTime @default(now())

  @@map("activity_log")
}
